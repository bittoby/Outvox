# ═══════════════════════════════════════════════════════════════════════════════
# OUTBOUND AGENT - ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp env.example .env
# ═══════════════════════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════════════════════════════
# AUTHENTICATION  (see SECURITY.md before deploying)
# ═══════════════════════════════════════════════════════════════════════════════
# Shared secret that callers must send in the X-API-Key header (or as a Bearer
# token) on every mutating route. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# If unset, the services log a loud warning at startup and allow all requests.
# DO NOT leave unset for any internet-reachable deployment.
API_KEY=

# Comma-separated path prefixes that bypass the API-key check. The default
# covers health checks, the Twilio voice + SMS webhooks (which validate
# X-Twilio-Signature themselves), the media-stream WebSocket (HMAC-protected),
# and the OpenAPI docs. Override only if you front the service with a different
# webhook surface.
# AUTH_EXEMPT_PREFIXES=/health,/nginx-health,/twilio-voice,/twilio-sms,/sms/twilio-sms,/api/sms/twilio-sms,/media-stream,/docs,/redoc,/openapi.json


# ═══════════════════════════════════════════════════════════════════════════════
# BRAND / TENANT  (controls every customer-facing string)
# ═══════════════════════════════════════════════════════════════════════════════
# The voice agent and SMS templates substitute these values at load time. Pick
# names that fit the business you're calling on behalf of.
COMPANY_NAME=Acme Pawn
COMPANY_SHORT_NAME=Acme
AGENT_NAME=Alex
COMPANY_TAGLINE=Trusted local pawn loans and appraisals.
COMPANY_OFFERING=pawn loans and quick cash for gold, jewelry, watches, and electronics


# ═══════════════════════════════════════════════════════════════════════════════
# OPENAI CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

OPENAI_API_KEY=sk-your-openai-api-key-here
REALTIME_MODEL=gpt-realtime-2025-08-28

# Voice Settings
TEMPERATURE=0.95                      # Higher = more natural/varied (0.8-1.0 recommended)
VAD_THRESHOLD=0.5                     # Voice Activity Detection sensitivity (0.0-1.0)
VAD_PREFIX_PADDING_MS=300             # Pre-speech buffer in milliseconds
VAD_SILENCE_DURATION_MS=500           # Silence duration before interruption


# ═══════════════════════════════════════════════════════════════════════════════
# TWILIO CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_CALL_TIMEOUT=30                # Seconds to wait for call to connect
CAMPAIGN_SID=CMxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Validate Twilio-originating HTTP webhooks. Keep enabled outside local mock
# demos. PUBLIC_WEBHOOK_BASE_URL must match the public URL Twilio calls when
# the app is behind ngrok, Nginx, or another proxy.
TWILIO_VALIDATE_SIGNATURE=true
PUBLIC_WEBHOOK_BASE_URL=https://your-subdomain.ngrok.app

# Protect Twilio Media Stream WebSocket URLs with a generated HMAC token.
# Uses MEDIA_STREAM_TOKEN_SECRET, TWILIO_AUTH_TOKEN, or API_KEY as the secret.
MEDIA_STREAM_VALIDATE_TOKEN=true
# MEDIA_STREAM_TOKEN_SECRET=generate-a-long-random-secret


# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# SQL Server is the supported runtime backend for v0.1.x. The repository layer
# still contains SQL Server-specific SQL. Postgres schema bootstrapping exists
# for migration work, but full Postgres runtime compatibility is not complete.

DATABASE_BACKEND=sqlserver
SQLServer=your-server-name
SQLUser=your_username
SQLPassword=your_password
SQLDatabase=your_database

# Experimental Postgres migration path:
# DATABASE_BACKEND=postgres
# DATABASE_URL=postgresql://outvox:outvox@localhost:5432/outvox


# ═══════════════════════════════════════════════════════════════════════════════
# NETWORK CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

NGROK_HOST=your-subdomain.ngrok.app
DB_SERVICE_URL=http://localhost:8000
PORT=5001


# ═══════════════════════════════════════════════════════════════════════════════
# CALL BEHAVIOR
# ═══════════════════════════════════════════════════════════════════════════════

MAX_CALL_DURATION=600                 # Maximum call duration in seconds (600 = 10 min)
ENABLE_CALL_RECORDING=true            # Enable/disable call recording (true/false)
ENFORCE_ENGLISH_ONLY=true             # Restrict to English responses (true/false)
MAX_RESPONSE_WORDS=20                 # Shorter = more natural (15-25 recommended)
VOICE_SELECTION=sage                  # Options: sage, echo, nova, onyx


# ═══════════════════════════════════════════════════════════════════════════════
# DNC (DO NOT CALL) DETECTION
# ═══════════════════════════════════════════════════════════════════════════════

SENTIMENT_THRESHOLD=-0.3              # Range: -1.0 to 1.0 (negative = add to DNC)


# ═══════════════════════════════════════════════════════════════════════════════
# SMS CAMPAIGN CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

SMS_CONSENT_COOLDOWN_DAYS=7           # Days before leads become eligible again
SMS_SEND_INTERVAL_SECONDS=300         # Interval between SMS sends (300 = 5 min)


# ═══════════════════════════════════════════════════════════════════════════════
# ELEVENLABS CONFIGURATION (Alternative Voice Provider)
# ═══════════════════════════════════════════════════════════════════════════════
# Get your API key from: https://elevenlabs.io/app/settings/api-keys

ELEVENLABS_API_KEY=sk_your_elevenlabs_api_key_here


# ═══════════════════════════════════════════════════════════════════════════════
# TRESTLE API CONFIGURATION (Phone Number Validation)
# ═══════════════════════════════════════════════════════════════════════════════
# Get your API key from: https://trestleiq.com/

TRESTLE_API_KEY=your_trestle_api_key_here
TRESTLE_VALIDATE_ON_CREATE=true       # Validate phone when creating leads
TRESTLE_VALIDATE_BEFORE_SMS=true      # Validate phone before sending SMS
TRESTLE_BLOCK_INVALID=true            # Block invalid numbers from campaigns
TRESTLE_BLOCK_LANDLINE_SMS=true       # Block landline numbers for SMS
TRESTLE_CACHE_HOURS=24                # Cache validation results (hours)
