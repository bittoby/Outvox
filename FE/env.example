# ═══════════════════════════════════════════════════════════════════════════════
# OUTBOUND AGENT FRONTEND - ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp env.example .env
# ═══════════════════════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════════════════════════════
# API CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Vite only exposes variables prefixed with VITE_ to the client bundle.

VITE_DB_SERVICE_URL="http://localhost:8000"
VITE_LOAD_BALANCER_URL="http://localhost:5100"


# ═══════════════════════════════════════════════════════════════════════════════
# AUTHENTICATION
# ═══════════════════════════════════════════════════════════════════════════════
# Must match the API_KEY set on the backend (BE/.env). The dashboard sends
# this in an X-API-Key header on every request. If you do not set this and
# the backend has an API_KEY configured, every request will be rejected.
#
# You can also set the key from DevTools at runtime by calling
#   setApiKey("...")
# in the browser console. The key will be persisted in localStorage.
VITE_API_KEY=""
